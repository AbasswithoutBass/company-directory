# === 基础配置 ===
# 服务端口
PORT=3000

# JWT 密钥(生产环境务必改!Render 部署时设为 generateValue)
JWT_SECRET=change-me-to-a-long-random-string-in-production

# 初始管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# === 部署到 Render / Railway 时用 ===
# 数据存储目录(指向 Render 持久卷,本地开发留空走默认 ./data)
# DATA_DIR=/opt/render/project/src/data

# 首次启动时自动写入示例员工(部署到 Render 设 true,本地开发留空)
# SEED_ON_BOOT=true
